# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
build/
.next/
.turbo/

# Stale TypeScript build artifacts in source dirs (Vite picks .js over .tsx)
apps/web/src/**/*.js
apps/web/src/**/*.js.map
apps/web/src/**/*.d.ts
apps/web/src/**/*.d.ts.map
# ...but vite-env.d.ts is hand-written source (declares __APP_VERSION__), not an artifact
!apps/web/src/vite-env.d.ts

# Emitted vite config artifacts — source is vite.config.ts, but a stray
# `tsc -b` emits vite.config.js/.d.ts at the package root, and Vite loads the
# .js in preference to the .ts, silently shadowing every config change.
# (tailwind.config.js / postcss.config.js are hand-written sources — keep those.)
apps/web/vite.config.js
apps/web/vite.config.js.map
apps/web/vite.config.d.ts
apps/web/vite.config.d.ts.map

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
desktop.ini

# Environment
.env
.env.*

# Service account keys / secrets — never commit these
apps/api/secrets/
secrets/

# Test coverage
coverage/

# Logs
*.log
npm-debug.log*

# Temp files
*.tmp
tmpclaude-*

# Data migration (real company data, generated schemas)
data_migration/data/
data_migration/schemas/
data_migration/logs/

# API runtime data (permissions JSON, future config files, etc.)
apps/api/data/

# TypeScript incremental build cache — churns on every build, must not be tracked
# (a dirty main checkout blocks the fast-forward merge in /feature-complete)
apps/api/tsconfig.tsbuildinfo

# Per-worktree dev server logs (see scripts/worktree/)
.dev-logs/

# Per-user Claude Code local settings (machine-specific; skills/ stay tracked)
.claude/settings.local.json

# One-off operational backfill scripts + their rollback snapshots. These are
# run-once data fixes against the live DB (kept on disk as recovery undo), not
# application source — see memories project_*_backfill. Scoped to apps/api so
# real source isn't caught.
apps/api/backfill-*
apps/api/*-rollback-*.json

# Playwright artifacts (baselines in apps/web/e2e/__screenshots__ ARE committed)
apps/web/test-results/
apps/web/playwright-report/
