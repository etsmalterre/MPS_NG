# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
build/
.next/
.turbo/

# Stale TypeScript build artifacts in source dirs (Vite picks .js over .tsx)
apps/web/src/**/*.js
apps/web/src/**/*.js.map
apps/web/src/**/*.d.ts
apps/web/src/**/*.d.ts.map

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
desktop.ini

# Environment
.env
.env.*

# Test coverage
coverage/

# Logs
*.log
npm-debug.log*

# Temp files
*.tmp
tmpclaude-*

# Data migration (real company data, generated schemas)
data_migration/data/
data_migration/schemas/
data_migration/logs/

# API runtime data (permissions JSON, future config files, etc.)
apps/api/data/
