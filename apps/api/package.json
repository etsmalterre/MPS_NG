{
  "name": "@mps/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:8081": "cross-env PORT=8081 tsx watch src/index.ts",
    "dev:8082": "cross-env PORT=8082 tsx watch src/index.ts",
    "dev:8083": "cross-env PORT=8083 tsx watch src/index.ts",
    "dev:8084": "cross-env PORT=8084 tsx watch src/index.ts",
    "dev:8085": "cross-env PORT=8085 tsx watch src/index.ts",
    "dev:8086": "cross-env PORT=8086 tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@mps/db": "workspace:*",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.38.3",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "postgres": "^3.4.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@types/supertest": "^6.0.3",
    "cross-env": "^10.1.0",
    "rimraf": "^6.0.1",
    "supertest": "^7.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.0.16"
  }
}
